  "query_examples": {
    "description": "Example queries to test relationships",
    "examples": [
      {
        "name": "Find person with all roles",
        "query": "QueryHelper.findPersonWithAllRoles(Person, johnSmithObjectId)",
        "returns": "John Smith's record + roles as tenant, renting from Ahmed & Fatima"
      },
      {
        "name": "Find property with all people",
        "query": "QueryHelper.findPropertyWithAllPeople(Property, propObjectId)",
        "returns": "Property 305 + owners (Ahmed 50%, Fatima 50%) + tenant (John) + agents (Mohammed)"
      },
      {
        "name": "Find co-owners of property",
        "query": "QueryHelper.getPropertyCoOwners(PropertyOwnership, propObjectId)",
        "returns": "Ahmed Hassan (50%), Fatima Ali (50%)"
      },
      {
        "name": "Get tenancy payment status",
        "query": "QueryHelper.getTenancyPaymentSummary(PropertyTenancy, tenancyObjectId)",
        "returns": "Total: 85,000 AED, Paid: 42,500, Unpaid: 42,500, Completion: 50%"
      },
      {
        "name": "Find overdue cheques",
        "query": "QueryHelper.findOverdueCheques(PropertyTenancy)",
        "returns": "Cheque CH-003 (21,250 AED, due 2024-08-15, overdue)"
      },
      {
        "name": "Validate no duplicate persons",
        "query": "ValidationHelper.checkPersonDuplicates(Person, 'John', 'Smith', '+971507654321')",
        "returns": "No duplicates found"
      },
      {
        "name": "Validate property composite key",
        "query": "ValidationHelper.validateCompositeKey(Property, 'CLUSTER-DAMAC-HILLS-2', '305')",
        "returns": "Composite key is unique"
      },
      {
        "name": "Validate landlords own property",
        "query": "ValidationHelper.validateLandlordsOwnProperty([ahmedId, fatimaId], propObjectId, PropertyOwnership)",
        "returns": "Both landlords own 50% each - validation passes"
      }
    ]
  },

  "data_entry_checklist": {
    "description": "Steps to manually enter sample data",
    "steps": [
      "1. Insert Developer record",
      "2. Insert Cluster record",
      "3. Insert FurnishingStatus, OccupancyStatus, AvailabilityStatus records",
      "4. Insert Person records (Ahmed, Fatima, John, Mohammed)",
      "5. Insert Property record (Unit 305)",
      "6. Insert PropertyOwnership records (Ahmed 50%, Fatima 50%)",
      "7. Insert PropertyTenancy record with 4 cheques",
      "8. Insert PropertyAgent record (Mohammed as rental agent)",
      "9. Verify all relationships using QueryHelper",
      "10. Update currentTenancyId and currentTenantPersonId in Property record"
    ]
  }
